# Скопируйте в .env и при необходимости поменяйте значения.

# Порт сервера
PORT=3000

# Секрет для подписи сессионных токенов (обязательно поменяйте в продакшене)
SESSION_SECRET=change-me-to-a-long-random-string

# Куда класть файл базы SQLite
DB_PATH=./data/app.db

# --- AI-ассистент (опционально) ---
# Если не задано — приложение работает полностью, AI просто выключен.
# Поддерживаемые провайдеры: openai | anthropic | gemini
AI_PROVIDER=
AI_API_KEY=
# Необязательно: переопределить модель
AI_MODEL=

# --- Push-уведомления (опционально) ---
# Контакт владельца для Web Push (VAPID). Ключи генерируются автоматически.
VAPID_SUBJECT=mailto:you@example.com
# false — выключить планировщик напоминаний (зарплата/дедлайны/цены)
PUSH_REMINDERS_ENABLED=true

# --- Monobank «план vs факт» (опционально) ---
# Personal token: https://api.monobank.ua/
MONOBANK_TOKEN=

# --- Offsite-копия бэкапов в GitHub (опционально) ---
# PAT с правом contents:write на приватный репозиторий
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=owner/backup-repo
GITHUB_BACKUP_BRANCH=main
